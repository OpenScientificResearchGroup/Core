# CoreConfig.cmake - 供其他项目使用

@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# 设置查找策略
set(CMAKE_FIND_PACKAGE_PREFER_CONFIG TRUE)

# 查找依赖
find_dependency(wxWidgets)
find_dependency(fmt)
find_dependency(spdlog)
find_dependency(nlohmann_json)
find_dependency(minizip-ng)

# 包含目标文件
if(EXISTS "${CMAKE_CURRENT_LIST_DIR}/CoreTargets.cmake")
    include("${CMAKE_CURRENT_LIST_DIR}/CoreTargets.cmake")
else()
    message(WARNING "CoreTargets.cmake not found in ${CMAKE_CURRENT_LIST_DIR}")
endif()

# 设置变量供其他项目使用
set(Core_FOUND TRUE)
set(Core_VERSION @PROJECT_VERSION@)
